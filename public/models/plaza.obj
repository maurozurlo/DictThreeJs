# plaza.obj — Reference mesh for the main plaza slab
# Dimensions: 10 m wide (X) x 0.2 m tall (Y) x 10 m deep (Z)
# Pivot:      bottom centre at local origin (0, 0, 0)
# Scale:      1 unit = 1 metre
# World pos:  (0, 0, -9) via street-placement.ipl.ts
#
# Import into 3ds Max and use as dimension reference.
# Delete or hide this object before starting final production assets.

g plaza

# Bottom ring (y = 0)
v -5.0  0.0 -5.0
v  5.0  0.0 -5.0
v  5.0  0.0  5.0
v -5.0  0.0  5.0
# Top ring (y = 0.2)
v -5.0  0.2 -5.0
v  5.0  0.2 -5.0
v  5.0  0.2  5.0
v -5.0  0.2  5.0

# Top face (normal +Y)
f 5 6 7
f 5 7 8
# Bottom face (normal -Y)
f 1 3 2
f 1 4 3
# Front face (normal +Z, z = +5)
f 4 7 3
f 4 8 7
# Back face (normal -Z, z = -5)
f 2 5 1
f 2 6 5
# Right face (normal +X, x = +5)
f 3 6 2
f 3 7 6
# Left face (normal -X, x = -5)
f 1 8 4
f 1 5 8
